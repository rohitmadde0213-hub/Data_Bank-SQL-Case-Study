#What is the closing balance for each customer at the end of the month?

with cte as 
(
		select 	customer_id, month(txn_date) month_ct,
		SUM(CASE WHEN txn_type = 'deposit' THEN txn_amount ELSE 0 END) AS deposit_count,
		SUM(CASE WHEN txn_type IN ('purchase', 'withdrawal') THEN txn_amount ELSE 0 END) AS pw_count
        from customer_transactions	
		group by customer_id,month(txn_date)
)        
select customer_id, month_ct, (deposit_count - pw_count) net_balance from cte where month_ct = 4;

#What is the percentage of customers who increase their closing balance by more than 5%?
#my approch comes over 80% correct 
with cte as 
(
		select 	customer_id, month(txn_date) month_ct,
		SUM(CASE WHEN txn_type = 'deposit' THEN txn_amount ELSE 0 END) AS deposit_count,
		SUM(CASE WHEN txn_type IN ('purchase', 'withdrawal') THEN txn_amount ELSE 0 END) AS pw_count
        from customer_transactions	
		group by customer_id,month(txn_date)
),        
cte2 as 
(	select 	customer_id, month_ct, 
			(deposit_count - pw_count) pre_month_balance, 
			lead(deposit_count - pw_count) over (order by month_ct) as current_balance
	from cte 
),
cte3 as 
(	select 	*,
			round(((current_balance - pre_month_balance) / pre_month_balance) * 100, 2) percentage_increase
	from cte2
)
select count(*)
from cte3
where percentage_increase > 5;


with monthly_balance as 
(select 	customer_id, 
		month(txn_date) mo,
		year(txn_date) yr,
        (SUM(CASE WHEN txn_type = 'deposit' THEN txn_amount ELSE 0 END) - 
        SUM(CASE WHEN txn_type IN ('purchase', 'withdrawal') THEN txn_amount ELSE 0 END)) AS closing_balance
from customer_transactions	
group by customer_id, month(txn_date), year(txn_date)
),
balance_change as 
(select customer_id,
    yr,
    mo,
    closing_balance,
		lag(closing_balance) over (partition by customer_id order by yr, mo) previous_balance
from monthly_balance 
),
filtered as 
(select customer_id,
		MAX(
      CASE 
        WHEN previous_balance IS NOT NULL 
         AND previous_balance <> 0
         AND ((closing_balance - previous_balance) / previous_balance) * 100 > 5
        THEN 1 ELSE 0 
      END
    ) AS has_increase
from balance_change
group by customer_id
)
select ROUND(
    SUM(has_increase) * 100.0 / COUNT(*),
  2)  as percentage_customer
from filtered;












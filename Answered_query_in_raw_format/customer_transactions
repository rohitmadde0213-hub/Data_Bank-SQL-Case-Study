use data_bank;
#What is the unique count and total amount for each transaction type?
#answer
select txn_type,  count(distinct customer_id)
from customer_transactions
group by txn_type;

#What is the average total historical deposit counts and amounts for all customers?
#answer
with cte as (select customer_id, count(*) deposit_count, sum(txn_amount) total_amount from customer_transactions
where txn_type = 'deposit'
group by customer_id)
SELECT 
  ROUND(AVG(deposit_count), 2) AS avg_deposit_count,
  ROUND(AVG(total_amount), 2) AS avg_deposit_amount
FROM cte;
;


#For each month - how many Data Bank customers make more than 1 deposit and either 1 purchase or 1 withdrawal in a single month?

with cte as 
(	select extract(month from txn_date) as month_c , count(*) deposit_count from  customer_transactions
	where txn_type = 'deposit'
	group by extract(month from txn_date), customer_id
	having count(*) > 1
),
cte2 as
(
	select extract(month from txn_date) as month_ce , count(*) pur_with_count from  customer_transactions
	where txn_type = 'purchase' or txn_type = 'withdrawal'
	group by extract(month from txn_date)
	having count(*) >= 1
)
select c.month_c, deposit_count, pur_with_count from  cte c join cte2 ce on c.month_c = ce.month_ce;


with cte as 
(	select customer_id, YEAR(txn_date) year_c, month(txn_date) month_c,
			sum(case when txn_type = 'deposit' then 1 else 0 end) as deposit_count,
			sum(case when txn_type IN ('purchase', 'withdrawal') then 1 else 0 end) as pur_with_count 
	from customer_transactions
	group by customer_id, month(txn_date),  YEAR(txn_date)
)
select year_c, month_c, count(customer_id) as count_of_tnx
from cte 
where deposit_count > 1 and pur_with_count >= 1
group by month_c, year_c;



with CTE as 
